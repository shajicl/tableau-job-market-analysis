      <column caption='Average Pay' datatype='real' default-format='c&quot;$&quot;#,##0;(&quot;$&quot;#,##0)' name='[Calculation_1947243936505798656]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Minimum Pay] + [Maximum Pay])/2' />
      </column>
      <column caption='Tableau Top 3' datatype='boolean' name='[Calculation_1947243936520605697]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF LOWER([Job Skills - Split 1]) = &quot;tableau&quot;&#13;&#10;OR LOWER([Job Skills - Split 2]) = &quot;tableau&quot;&#13;&#10;OR LOWER([Job Skills - Split 3]) = &quot;tableau&quot;&#13;&#10;OR LOWER([Job Skills - Split 4]) = &quot;tableau&quot;&#13;&#10;OR LOWER([Job Skills - Split 5]) = &quot;tableau&quot;&#13;&#10;OR LOWER([Job Skills - Split 6]) = &quot;tableau&quot;&#13;&#10;OR LOWER([Job Skills - Split 7]) = &quot;tableau&quot;&#13;&#10;OR LOWER([Job Skills - Split 8]) = &quot;tableau&quot;&#13;&#10;OR LOWER([Job Skills - Split 9]) = &quot;tableau&quot;&#13;&#10;OR LOWER([Job Skills - Split 10]) = &quot;tableau&quot;&#13;&#10;OR LOWER([Job Skills - Split 11]) = &quot;tableau&quot;&#13;&#10;OR LOWER([Job Skills - Split 12]) = &quot;tableau&quot;&#13;&#10;OR LOWER([Job Skills - Split 13]) = &quot;tableau&quot;&#13;&#10;OR LOWER([Job Skills - Split 14]) = &quot;tableau&quot;&#13;&#10;OR LOWER([Job Skills - Split 15]) = &quot;tableau&quot;&#13;&#10;OR LOWER([Job Skills - Split 16]) = &quot;tableau&quot;&#13;&#10;THEN TRUE&#13;&#10;ELSE FALSE&#13;&#10;END' />
      </column>
      <column caption='Tableau Skill' datatype='boolean' name='[Calculation_2252644287807111168]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CONTAINS(LOWER([Job Skills]), &quot;tableau&quot;)' />
      </column>
